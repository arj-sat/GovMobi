<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <EditText
            android:id="@+id/edit_license_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="License Type" />

        <EditText
            android:id="@+id/edit_license_number"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="License Number"
            android:layout_marginTop="16dp"/>

        <EditText
            android:id="@+id/edit_expiry_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Expiry Date (dd/MM/yyyy)"
            android:layout_marginTop="16dp"/>

        <EditText
            android:id="@+id/edit_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Status (Valid/Expired)"
            android:layout_marginTop="16dp"/>

        <Button
            android:id="@+id/button_save_license"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save License"
            android:layout_marginTop="24dp" />
    </LinearLayout>
</ScrollView>
